# Enforce LF line endings in the repo for all text files.
# Overrides core.autocrlf on Windows so contributors never see
# "LF will be replaced by CRLF" warnings.
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.msi  binary
*.exe  binary
*.dll  binary
*.so   binary
*.dylib binary

# JS/TS minified bundles — binary-treat to avoid diff noise
*.min.js  binary
*.min.css binary

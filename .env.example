## Database
# Docker Compose default (pgbouncer connection pooler)
DATABASE_URL=postgresql+asyncpg://remembr:remembr@pgbouncer:6432/remembr
# Bare install / local development (direct postgres)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/remembr

## Redis
REDIS_URL=redis://redis:6379
# Bare install: redis://localhost:6379

## Auth
SECRET_KEY=change-me-in-production

## Environment
ENVIRONMENT=local
LOG_LEVEL=INFO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

## Embeddings
# Docker Compose default: ollama  (bundled, no API key needed)
# Bare pip install default: sentence_transformers
# Supported values: sentence_transformers | ollama | jina | openai
EMBEDDING_PROVIDER=ollama

# sentence_transformers: local model download on first use, no API key needed
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# ollama: uses the bundled Ollama container
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# jina: only needed when EMBEDDING_PROVIDER=jina
# JINA_API_KEY=your-jina-api-key
# JINA_EMBEDDING_MODEL=jina-embeddings-v3

# openai: only needed when EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

## Observability
OTEL_ENABLED=false
# OTEL_EXPORTER_ENDPOINT=http://localhost:4317

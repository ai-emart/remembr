# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remembr

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=INFO

# ── Embedding provider ────────────────────────────────────────────────────────
# One of: sentence_transformers | jina | ollama | openai
EMBEDDING_PROVIDER=sentence_transformers

# sentence_transformers — works with no API key (model downloaded on first use)
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# jina — set EMBEDDING_PROVIDER=jina and provide a key
# JINA_API_KEY=
# JINA_EMBEDDING_MODEL=jina-embeddings-v3

# ollama — set EMBEDDING_PROVIDER=ollama and run Ollama locally
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# openai — set EMBEDDING_PROVIDER=openai and provide a key
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

## Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remembr

## Redis
REDIS_URL=redis://localhost:6379

## Auth
SECRET_KEY=change-me-in-production

## Environment
ENVIRONMENT=local
LOG_LEVEL=INFO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

## Embeddings
# Default for bare pip installs: sentence_transformers.
# Supported values: sentence_transformers | jina | ollama | openai
EMBEDDING_PROVIDER=sentence_transformers

# sentence_transformers: local model download on first use, no API key needed
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# jina: optional unless EMBEDDING_PROVIDER=jina
# JINA_API_KEY=your-jina-api-key
# JINA_EMBEDDING_MODEL=jina-embeddings-v3

# ollama: use the bundled local service or your own endpoint
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# openai: optional unless EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

## Observability
OTEL_ENABLED=false
# OTEL_EXPORTER_ENDPOINT=http://localhost:4317
